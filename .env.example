# Server
PORT=3000

# Optional: set for real AI generation (get key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
# Primary model — app auto-rotates through fallbacks if quota is hit
GEMINI_MODEL=gemini-2.5-flash

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REDIRECT_URL=http://localhost:3000

# Auth policy
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_REQUIRE_EMAIL_CONFIRMATION=true

# Optional deploy hooks
NETLIFY_DEPLOY_HOOK_URL=
VERCEL_DEPLOY_HOOK_URL=

# Admin security (required for /admin access)
ADMIN_USERNAME=
ADMIN_EMAIL=
# Hash format: sha256("<ADMIN_PASSWORD_SALT>:<plain_password>") in lowercase hex
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_SALT=
# Long random secret for signing admin session tokens
ADMIN_AUTH_SECRET=
